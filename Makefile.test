COVERAGE_FILE=coverage.out
MIN_COVERAGE=70

# Собираем все пакеты проекта, исключая моки, протобафы, документацию, codegen для easyjson.
# Пакеты перечисляются через пробел для передачи в качестве аргументов go test.
PACKAGES := $(shell go list ./... | grep -vE "mock|proto|docs|dto")

# Пакеты для инструментирования через -coverpkg.
# Для корректной статистики исключаем также пакеты 'cmd' (точки входа).
# Объединяем через запятую с помощью paste.
COVERPKG := $(shell go list ./... | grep -vE "mock|proto|docs|cmd|dto" | paste -sd "," -)

.PHONY: unit unit-only-fail cover report ci clean

unit:
	@go test -v -race $(PACKAGES)

unit-only-fail:
	@go test -v $(PACKAGES) | grep -E "FAIL|--- FAIL|Error:"

cover: clean
	@go test -count=1 -timeout=5m -race \
		-coverpkg=$(COVERPKG) \
		-coverprofile=$(COVERAGE_FILE) \
		$(PACKAGES)

report: cover
	@go tool cover -html=$(COVERAGE_FILE)

ci: cover
	@TOTAL_COVERAGE=$$(go tool cover -func=$(COVERAGE_FILE) | grep total | awk '{print $$3}' | tr -d '%'); \
	echo "Total coverage: $$TOTAL_COVERAGE%"; \
	if [ $$(echo "$$TOTAL_COVERAGE < $(MIN_COVERAGE)" | bc -l) -eq 1 ]; then \
		echo "FAILED: Coverage is below $(MIN_COVERAGE)%"; \
		exit 1; \
	fi

clean:
	@rm -f $(COVERAGE_FILE)
	@go clean -testcache
